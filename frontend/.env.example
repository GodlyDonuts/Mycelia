# Mycelia configuration — all optional. Copy to .env.local and fill what you need.

# Enables real Claude Opus 4.8 natural-language job parsing on /api/jobs/parse.
# Without it, a deterministic keyword fallback is used (the app works either way).
ANTHROPIC_API_KEY=

# Override the model id used for NL parsing (default: claude-opus-4-8).
ANTHROPIC_MODEL=claude-opus-4-8

# Persist the embedded PGlite database to this directory instead of in-memory.
# Leave unset for an in-memory DB that re-seeds on every server start.
# MYCELIA_DB_DIR=.pglite

# Set to "dsql" to use Amazon Aurora DSQL instead of local PGlite.
# Leave unset for the default embedded PGlite development database.
# MYCELIA_DB_BACKEND=dsql

# Aurora DSQL connection settings. Required only when MYCELIA_DB_BACKEND=dsql
# or when running `pnpm db:dsql:migrate`.
# DSQL_ENDPOINT=your-cluster-id.dsql.us-east-1.on.aws
# AWS_REGION=us-east-1
# DSQL_CA_BUNDLE=./certs/global-bundle.pem

# Optional DSQL overrides. Defaults match the initial admin-token bootstrap path.
# DSQL_DATABASE=postgres
# DSQL_USER=admin
# DSQL_PORT=5432
# DSQL_POOL_MAX=1
# DSQL_USE_ADMIN_TOKEN=true
