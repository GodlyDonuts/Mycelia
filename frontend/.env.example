# Mycelia configuration — all optional. Copy to .env.local and fill what you need.

# Enables real Claude Opus 4.8 natural-language job parsing on /api/jobs/parse.
# Without it, a deterministic keyword fallback is used (the app works either way).
ANTHROPIC_API_KEY=

# Override the model id used for NL parsing (default: claude-opus-4-8).
ANTHROPIC_MODEL=claude-opus-4-8

# Persist the embedded PGlite database to this directory instead of in-memory.
# Leave unset for an in-memory DB that re-seeds on every server start.
# MYCELIA_DB_DIR=.pglite

# ─── AWS database backend ───────────────────────────────────────────────────
# Selects the data-layer driver. Unset/pglite = embedded (default; no cloud).
#   dsql      → Aurora DSQL (IAM-token auth, RDS-CA TLS, keep-alive, 40001 retry)
#   postgres  → Aurora PostgreSQL / RDS / any Postgres via DATABASE_URL
# MYCELIA_DB_DRIVER=postgres

# --- driver=postgres (Aurora PostgreSQL / RDS / Neon / local) ---
# DATABASE_URL=postgres://user:pass@your-cluster.cluster-xxxx.us-east-1.rds.amazonaws.com:5432/postgres
# DATABASE_SSL=verify          # verify (default) | no-verify | disable
# DATABASE_CA_BUNDLE=/path/to/rds-global-bundle.pem   # optional, pins the RDS CA

# --- driver=dsql (Aurora DSQL) ---
# DSQL_ENDPOINT=your-cluster-id.dsql.us-east-1.on.aws
# AWS_REGION=us-east-1
# DSQL_USER=admin              # admin (default) mints an admin auth token
# DSQL_CA_BUNDLE=/path/to/rds-global-bundle.pem   # optional; else system trust store
# AWS auth itself comes from the standard provider chain (OIDC→IAM role preferred,
# or `aws configure`); never put static AWS keys here.

# Skip seeding a populated demo mesh on an already-provisioned cloud DB.
# MYCELIA_DB_SEED=false
